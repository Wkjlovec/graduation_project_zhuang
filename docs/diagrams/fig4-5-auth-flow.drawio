        <mxCell id="s3" value="锁定 600 秒" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="450" width="100" height="40" as="geometry"/>
