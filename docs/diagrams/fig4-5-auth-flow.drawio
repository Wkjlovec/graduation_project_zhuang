        <mxCell id="err1" value="返回错误" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="70" width="90" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="Yes" style="rounded=0;html=1;strokeWidth=1.2;fontSize=10;" edge="1" source="d1" target="err1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
