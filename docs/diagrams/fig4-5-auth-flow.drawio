        <mxCell id="d1" value="账户&lt;br&gt;已锁定？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="190" y="190" width="110" height="80" as="geometry"/>
