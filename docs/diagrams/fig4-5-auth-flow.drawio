          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="Redis&lt;br&gt;失败计数+1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
