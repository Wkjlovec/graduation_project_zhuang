        <mxCell id="d2" value="校验用户名&lt;br&gt;和密码" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="345" y="185" width="120" height="90" as="geometry"/>
